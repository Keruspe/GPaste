#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:53
msgid ""
"GNOME Shell extension: fix history items gradually disappearing from the menu"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:54

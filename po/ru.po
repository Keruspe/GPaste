msgid "Fix building without the GNOME Shell extension (-Dgnome-shell=false)"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:54
msgid ""
"Restore GTK deprecation version-gating and drop the unused build-time gjs "
"dependency"

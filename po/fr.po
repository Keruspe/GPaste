#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:110
msgid "Fix a typo in the French translation"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:82
msgid "Fix building without the GNOME Shell extension (-Dgnome-shell=false)"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:83
msgid ""
"Restore GTK deprecation version-gating and drop the unused build-time gjs "
"dependency"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:84
msgid "Target GNOME Shell 50 in the extension"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:85
msgid "Bump the library soversions to reflect the API/ABI changes since 45.8"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:91
msgid ""
"This is a major release porting GPaste to GTK 4 and libadwaita. Changes:"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:93
msgid "Port the daemon, history UI and preferences to GTK 4 and libadwaita"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:94
msgid "Show image thumbnails in the history, with configurable preview size"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:95
msgid ""
"Support global keyboard shortcuts on Wayland through the XDG GlobalShortcuts "
"portal"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:96
msgid "Recognise copied colours as dedicated colour items"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:97
msgid ""
"Give keybindings human-readable descriptions and install a daemon desktop "
"file"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:98
msgid "Fix images sometimes being repeatedly re-added to the history"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:99
#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:119
msgid ""
"Fix keyboard shortcuts not triggering when NumLock and CapsLock are both "
"active"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:100
msgid ""
"Fix several crashes (search provider, UI lifetime, GNOME Shell extension) "
"and memory leaks"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:101
msgid "Modernise the GNOME Shell extension to current conventions"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:118
msgid "Fix use-after-free crash in the GNOME Shell search provider"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:120
msgid ""
"Fix memory leaks when re-copying history items and when rebinding shortcuts"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:121
msgid "Fix potential crash when enforcing a very small history size"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:122
msgid "Build: ship the GSettings schema as a static file"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:130
msgid ""
"GNOME Shell extension now retries the daemon connection before giving up"
msgstr ""


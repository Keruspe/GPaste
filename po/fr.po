#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:109
msgid "GNOME Shell extension: restore keyboard navigation of history items"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:72
msgid ""
"GNOME Shell extension: restore the Ctrl index overlay and Ctrl+0-9 selection"
msgstr ""

#: data/metainfo/org.gnome.GPaste.Ui.metainfo.xml.in:73
msgid "Build: require GTK 4.18"
msgstr ""

